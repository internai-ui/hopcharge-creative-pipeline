# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hopcharge_ad_engine

# Anthropic
ANTHROPIC_API_KEY=

# Meta
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_APP_ID=
META_APP_SECRET=

# Video + image generators
# Higgsfield (image: text2image/soul, video: image2video/dop). v2 auth = KEY_ID:KEY_SECRET.
HIGGSFIELD_KEY_ID=
HIGGSFIELD_KEY_SECRET=
HIGGSFIELD_ALLOW_GENERATION=false   # credit gate - must be "true" to spend credits
# HIGGSFIELD_SARA_SOUL_ID=          # trained character -> custom_reference_id (image consistency)
# HIGGSFIELD_SARA_REFERENCE_URL=    # public Sara still -> image_reference + video first frame
# HIGGSFIELD_SOUL_SIZE=1536x2048    HIGGSFIELD_SOUL_QUALITY=1080p
# HIGGSFIELD_DOP_MODEL=dop-turbo    HIGGSFIELD_DOP_MOTION_ID=   HIGGSFIELD_DOP_MOTION_STRENGTH=0.8
KLING_API_KEY=
RUNWAY_API_KEY=

# Image generators
REPLICATE_API_KEY=
MIDJOURNEY_API_KEY=

# Plugin selection
IDEA_GENERATOR=stub
VIDEO_GENERATOR=stub
IMAGE_GENERATOR=stub
PUBLISHER_META=stub
ANALYTICS_META=stub
TREND_DATA=stub
# Trend refresh mode: lite = Google Trends only (free, no AI) | full = + Claude web search & synthesis
TREND_MODE=lite
WEB_SEARCH=stub
AD_LIBRARY=stub

# Storage
# STORAGE_TYPE: "local" (plain disk) or "s3" (any S3-compatible backend).
# Dev default below targets local MinIO (run `npm run storage:up`).
STORAGE_TYPE=s3
STORAGE_LOCAL_PATH=./storage
# --- S3 / R2 / MinIO (only used when STORAGE_TYPE=s3) ---
# Local MinIO dev values:
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_BUCKET=hopcharge-creatives
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
# To switch to Cloudflare R2, change the 5 vars above to:
#   AWS_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   AWS_S3_BUCKET=<your-r2-bucket>
#   AWS_REGION=auto
#   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY=<R2 API token>
# (For real AWS S3 instead: leave AWS_S3_ENDPOINT blank and use your real region.)

# Background job automation master switch.
# false (default) = fully-manual mode: jobs only run when you trigger them via
#   the UI buttons / API endpoints. true = pg-boss schedules the recurring jobs
#   below at server startup.
ENABLE_JOB_AUTOMATION=false

# Job schedule overrides (cron syntax)
CRON_TREND_CONTEXT=0 6 * * *
CRON_FEEDBACK_LOOP=0 8 * * *
CRON_SYNC_PERFORMANCE=0 */6 * * *
CRON_POLL_CREATIVES=*/1 * * * *
